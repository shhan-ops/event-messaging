NODE_ENV=development

OMS_BACKEND_PORT=3001
OMS_BACKEND_USE_SWAGGER=true

OMS_BACKEND_DB_HOST=127.0.0.1
OMS_BACKEND_DB_PORT=5432
OMS_BACKEND_DB_USER=postgres
OMS_BACKEND_DB_PASSWORD=postgres
OMS_BACKEND_DB_NAME=oms_backend
OMS_BACKEND_DB_SCHEMA=public
OMS_BACKEND_DB_SSL=false

OMS_BACKEND_REDIS_URL=redis://default:mypassword@127.0.0.1:6379

OMS_BACKEND_OUTBOX_BATCH_SIZE=20
OMS_BACKEND_OUTBOX_MAX_RETRIES=5
OMS_BACKEND_PII_RESPONSE_GROUP=CG_OMS
OMS_BACKEND_PII_RESPONSE_CONSUMER=oms_backend
